<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="lab-4-2"/>
        <attribute name="authors" value="pelly"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-07-13 07:30:02 PM"/>
        <attribute name="created" value="cGVsbHk7TEFQVE9QLUhCN0RDTlMwOzIwMjYtMDctMTM7MDc6MTM6MDkgUE07Mjg4MQ=="/>
        <attribute name="edited" value="cGVsbHk7TEFQVE9QLUhCN0RDTlMwOzIwMjYtMDctMTM7MDc6MzA6MDIgUE07MTsyOTgx"/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="income" type="Integer" array="False" size=""/>
            <input variable="income"/>
            <declare name="totalTax" type="Integer" array="False" size=""/>
            <if expression="income &gt;= 50000">
                <then>
                    <if expression="income &gt;= 100000">
                        <then>
                            <assign variable="totalTax" expression="(50000 * 0.01) + ((income - 100000) * 0.02)"/>
                        </then>
                        <else>
                            <assign variable="totalTax" expression="(income - 50000) * 0.01"/>
                        </else>
                    </if>
                </then>
                <else>
                    <assign variable="totalTax" expression="income * 0.0"/>
                </else>
            </if>
            <output expression="totalTax" newline="True"/>
        </body>
    </function>
</flowgorithm>
